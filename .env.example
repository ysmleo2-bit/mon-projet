# === TELEGRAM ===
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# === ICLOSED API ===
ICLOSED_API_KEY=your_iclosed_api_key_here
ICLOSED_BASE_URL=https://api.iclosed.io/v1

# === GOOGLE SHEETS (optionnel) ===
GOOGLE_SHEET_ID=your_google_sheet_id_here
GOOGLE_CREDENTIALS_FILE=credentials.json

# === CONFIGURATION ===
# Heure du récap quotidien (format 24h, fuseau Europe/Paris)
RECAP_HOUR=9
RECAP_MINUTE=0
TIMEZONE=Europe/Paris

# Port du serveur webhook Zapier
WEBHOOK_PORT=5000
WEBHOOK_SECRET=your_secret_token_for_zapier
