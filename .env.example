# ============================================================
# Agent iClosed ↔ Telegram — Configuration
# ============================================================
# 1. Copie ce fichier : cp .env.example .env
# 2. Remplis les valeurs (ne pas mettre .env dans git)

# --- TELEGRAM (obligatoire) ---
# Obtenir via @BotFather sur Telegram
TELEGRAM_BOT_TOKEN=

# Ton Chat ID — envoie /start à @userinfobot sur Telegram
TELEGRAM_CHAT_ID=

# --- GOOGLE SHEETS (recommandé — source Zapier) ---
# ID du Google Sheet (dans l'URL : .../spreadsheets/d/ID_ICI/edit)
GOOGLE_SHEETS_ID=

# Chemin vers le fichier credentials JSON du Service Account Google
GOOGLE_CREDENTIALS_PATH=credentials.json

# Nom de l'onglet (laisser vide = premier onglet auto-détecté)
SHEETS_TAB_NAME=

# Noms des colonnes dans ton Sheet (adapter si différent)
SHEETS_DATE_COL=Date
SHEETS_STATUS_COL=Status
SHEETS_NAME_COL=Name
SHEETS_CLOSER_COL=Closer

# --- ICLOSED API (optionnel — si tu as une clé API iClosed) ---
ICLOSED_API_KEY=
ICLOSED_BASE_URL=https://api.iclosed.io/v1

# --- PLANNING DU RÉCAP ---
RECAP_HOUR=9
RECAP_MINUTE=0
TIMEZONE=Europe/Paris

# --- SERVEUR WEBHOOK ZAPIER (optionnel) ---
WEBHOOK_PORT=5002
# Secret pour sécuriser les webhooks (mettre une valeur aléatoire)
WEBHOOK_SECRET=
